OPENAI_API_KEY=ENTER_YOUR_KEY!
GEMINI_API_KEY=ENTER_YOUR_KEY!

# Faster image queue for Gemini (default on). Set to 0 if you prefer default API tier.
# GEMINI_PRIORITY_IMAGE_TIER=1

# ComicScript: set to 1 to use DSPy (same prompts as direct OpenAI; see src/generation/script_prompts.py)
# COMIC_USE_DSPY=1

# Optional: load a DSPy program saved after `uv run python -m src.generation.dspy_optimize`
# DSPY_COMIC_PROGRAM_PATH=data/dspy_comic_script_program.json

# LiteLLM (DSPy): set to 0 to disable dropping unknown params (default 1 = drop, avoids GPT-5 param errors)
# LITELLM_DROP_PARAMS=1